// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TokenType {
  ACCESS
  REFRESH
  EMAIL_VERIFICATION
  RESET_PASSWORD
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name String @db.VarChar(256)
  last_name String @db.VarChar(256)
  email String @unique @db.VarChar(256)
  is_email_verified Boolean @default(false)
  mobile_number String @db.VarChar(256)
  password String @db.VarChar(256)
  weddings Wedding[]
  tokens Token[]
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  
  @@index([email])
}

model Wedding {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user User @relation(fields: [user_id], references: [id])
  user_id String @db.Uuid
  slug String @db.VarChar(256)
  title String @db.VarChar(256)
  bride_name String @db.VarChar(256)
  groom_name String @db.VarChar(256)
  date DateTime @db.Date
  venue String @db.Text
  city String @db.VarChar(256)
  message String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)  

  @@index([user_id])
}

model Token{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jti String @db.Uuid
  user User @relation(fields: [user_id], references: [id])
  user_id String @db.Uuid
  token_type TokenType @default(ACCESS)
  expires_at DateTime
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id])
  @@index([jti])
}

